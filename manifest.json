{
  "manifest_version": 3,
  "name": "标签书签管理器",
  "version": "1.1.0",
  "description": "使用标签管理浏览器书签，在书签名字后添加 #标签 来分类。支持重新命名书签并同步到浏览器。",
  "icons": {
    "16": "img/icon_bookmark.png",
    "48": "img/icon_bookmark.png",
    "128": "img/icon_bookmark.png"
  },
  "action": {
    "default_icon": {
      "16": "img/icon_bookmark.png",
      "48": "img/icon_bookmark.png",
      "128": "img/icon_bookmark.png"
    },
    "default_title": "标签书签"
  },
  "permissions": ["bookmarks"],
  "chrome_url_overrides": {
    "newtab": "index.html"
  }
}